# Nyth Router environment template
# Copy this file to .env and adjust values. Never commit .env.

# Required on first boot: dashboard login password. Minimum 15 characters.
# The dashboard uses this password before you can manage providers, routes, and API keys.
NYTH_PASSWORD=<dashboard-password-min-15-chars>

# Optional: master secret used to encrypt provider keys at rest.
# If not set, Nyth auto-generates one and stores it locally in server/data/master.key.
# Set this explicitly in production-like setups so you control backup/restore.
NYTH_MASTER_KEY=

# Local default. Open http://localhost:9879/ after npm start.
HOST=localhost
PORT=9879
PUBLIC_BASE_URL=http://localhost:9879

# Optional: SQLite database path. Defaults to server/data/nyth.db
NYTH_DB_PATH=

# Optional: log retention in days for request_logs (0 = keep forever).
NYTH_LOG_RETENTION_DAYS=30

# Optional: prompt logging mode. One of: off, metadata, preview, full.
# Default is "preview" which stores a short snippet only.
NYTH_PROMPT_LOG_MODE=preview
