# Bigliner local-first AI gateway
# Copy this file to .env and adjust values. Never commit .env.

# Required: dashboard login password.
BIGLINER_PASSWORD=change-me

# Optional: master secret used to encrypt provider keys at rest.
# If not set, Bigliner will auto-generate one and store it locally in server/data/master.key.
# Set this explicitly in production-like setups so you control the secret.
BIGLINER_MASTER_KEY=

# Optional: backend host/port. Defaults are localhost:9879.
PORT=9879
HOST=localhost

# Optional: SQLite database path. Defaults to server/data/bigliner.db
BIGLINER_DB_PATH=

# Optional: log retention in days for request_logs (0 = keep forever).
BIGLINER_LOG_RETENTION_DAYS=30

# Optional: prompt logging mode. One of: off, metadata, preview, full.
# Default is "preview" which stores a short snippet only.
BIGLINER_PROMPT_LOG_MODE=preview
